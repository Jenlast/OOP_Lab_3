<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OOP_Lab3.ViewModels"
        x:Class="OOP_Lab3.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ООП Лабораторна" Width="800" Height="600">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Меню навігації -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10">
            <Button Content="Завдання 1" Command="{Binding OpenTask1}"/>
            <Button Content="Завдання 2" Command="{Binding OpenTask2}"/>
        </StackPanel>

        <!-- Зона, де змінюються завдання (Роутинг) -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        
    </Grid>
</Window>