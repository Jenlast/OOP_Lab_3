<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OOP_Lab3.ViewModels"
             x:Class="OOP_Lab3.Views.Task1View"
             x:DataType="vm:Task1ViewModel">

    <Grid ColumnDefinitions="300, *">
        
        <!-- Ліва панель керування -->
        <StackPanel Grid.Column="0" Spacing="10" Margin="20">
            <TextBlock Text="Налаштування генерації" FontWeight="Bold" FontSize="16"/>
            
            <TextBlock Text="Початок:" />
            <NumericUpDown Value="{Binding StartValue}" FormatString="0" />
            
            <TextBlock Text="Кінець:" />
            <NumericUpDown Value="{Binding EndValue}" FormatString="0" />
            
            <TextBlock Text="Крок (може бути від'ємним):" />
            <NumericUpDown Value="{Binding StepValue}" FormatString="0" />
            
            <Button Content="Створити кнопки" 
                    Command="{Binding GenerateButtonsCommand}" 
                    HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center"
                    Background="Green"/>

            <Separator Margin="0, 10" />

            <TextBlock Text="Керування видаленням" FontWeight="Bold" FontSize="16"/>
            <TextBlock Text="Введіть число кратності:" />
            <NumericUpDown Value="{Binding MultipleValue}" FormatString="0" />
            
            <Button Content="Видалити кратні кнопки" 
                    Command="{Binding DeleteMultiplesCommand}" 
                    HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center"
                    Background="Coral"/>
                    
            <!-- Додана кнопка повного очищення -->
            <Button Content="Очистити всі кнопки" 
                    Command="{Binding ClearAllCommand}" 
                    HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center"
                    Background="Gray"
                    Margin="0,5,0,0"/>

            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="Red" 
                       TextWrapping="Wrap" 
                       Margin="0,10,0,0"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            
            <Separator Margin="0, 10" />
            
            <!-- Інформаційна панель -->
            <Border Background="#007bffff" BorderBrush="#0066CC" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="Інформація про число:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding NumberInfo}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
        </StackPanel>

        <!-- Права панель з кнопками -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="10">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding GeneratedNumbers}" Margin="10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NumberItem">
                            <!-- ЗМІНА ТУТ: CommandParameter="{Binding .}" передає об'єкт цілком -->
                            <Button Content="{Binding Value}" 
                                    Command="{Binding $parent[UserControl].((vm:Task1ViewModel)DataContext).ShowNumberInfoCommand}"
                                    CommandParameter="{Binding .}" 
                                    Width="80" Height="50" 
                                    Margin="5"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>