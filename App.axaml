<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:OOP_Lab3"
             xmlns:views="using:OOP_Lab3.Views"
             xmlns:vms="using:OOP_Lab3.ViewModels"
             x:Class="OOP_Lab3.App">

    <Application.DataTemplates>
        <!-- Зв'язуємо ViewModels із Views -->
        <DataTemplate DataType="{x:Type vms:Task1ViewModel}">
            <views:Task1View />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:Task2ViewModel}">
            <views:Task2View />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>